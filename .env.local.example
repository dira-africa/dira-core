# Telegram Mini App Configuration
NEXT_PUBLIC_TELEGRAM_BOT_NAME=DiraWeatherBot
NEXT_PUBLIC_ENVIRONMENT=development

# Backend API URL (Fastify backend)
NEXT_PUBLIC_FASTIFY_API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Pretium Cash-out Activation Flag
NEXT_PUBLIC_PRETIUM_ACTIVE=false

# Hedera Configuration
NEXT_PUBLIC_HEDERA_NETWORK=testnet
NEXT_PUBLIC_HEDERA_TOKEN_ID=your_hedera_token_service_token_id
