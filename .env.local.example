# Telegram Mini App Configuration
NEXT_PUBLIC_TELEGRAM_BOT_NAME=DiraWeatherBot
NEXT_PUBLIC_ENVIRONMENT=development

# Backend API URL (Fastify backend)
NEXT_PUBLIC_FASTIFY_API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Safaricom Daraja B2C M-Pesa Flag Gate
NEXT_PUBLIC_DARAJA_PRODUCTION_ACTIVE=false

# XION Account Abstraction & Treasury Configuration
# Deploy a Treasury Contract in the XION Developer Portal (app.dev.testnet.burnt.com)
# 1. New Treasury -> Fee Grant: /cosmwasm.feegrant.v1beta1.BasicAllowance
# 2. Set redirect URL: https://app.diraafrica.org
# 3. Fund it with XION to sponsor user gas
# 4. Copy the Treasury address here
NEXT_PUBLIC_XION_TREASURY_CONTRACT_ADDRESS=xion1yourtreasurycontractaddresstestnet
NEXT_PUBLIC_XION_RPC_URL=https://rpc.xion-testnet-2.burnt.com:443
